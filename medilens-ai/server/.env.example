# App
ENVIRONMENT=development

# CORS (comma-separated list is fine to add later; Phase 1 uses default in config.py)

# Database (Supabase PostgreSQL) - required from Phase 4 onward
DATABASE_URL=postgresql://user:password@host:5432/dbname
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-supabase-service-key

# Auth - required from Phase 2 onward
JWT_SECRET_KEY=replace-with-a-long-random-secret
JWT_ALGORITHM=HS256

# AI - required from Phase 5 onward
GEMINI_API_KEY=your-gemini-api-key
