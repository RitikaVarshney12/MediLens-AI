# App
ENVIRONMENT=development

# CORS (comma-separated list is fine to add later; Phase 1 uses default in config.py)

# Database (Supabase PostgreSQL) - required from Phase 3 onward
DATABASE_URL=postgresql://user:password@host:5432/dbname
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-supabase-anon-key

# Service role key (Project Settings -> API) - server-only, bypasses RLS, never expose to the frontend
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# JWT Secret (Project Settings -> API -> JWT Settings) - verifies tokens issued by Supabase Auth
SUPABASE_JWT_SECRET=your-supabase-jwt-secret

# Auth - required from Phase 2 onward
JWT_SECRET_KEY=replace-with-a-long-random-secret
JWT_ALGORITHM=HS256

# Report uploads - Phase 3
STORAGE_BUCKET=medical-reports
MAX_UPLOAD_SIZE_MB=20

# AI - required from Phase 5 onward
GEMINI_API_KEY=your-gemini-api-key